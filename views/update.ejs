<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Page</title>
    <link rel="stylesheet" href="/styles.css">

</head>

<body>
    <%- include('navbar') %>
        <div class="div">
            <div class="div2">
                <h1>Update Task</h1>
                <form action="/edit/<%=data._id%>" method="post" class="form">
                    <input class="input" type="text" id="task" name="task" value="<%=data.task%>" required><br><br>
                    <button type="submit" class="sb-btn">Update</button>
                </form>
            </div>
        </div>
</body>

</html>